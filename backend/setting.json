{
    "python.autoComplete.extraPaths": [
        "${workspaceFolder}"
    ],
    "python.analysis.extraPaths": [
        "${workspaceFolder}",
        "${workspaceFolder}/services"
    ],
    "python.analysis.diagnosticSeverity": {
        "reportMissingImports": "warning",
        "reportMissingModuleSource": "warning"
    },

    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/.git/**": true,
        "**/dist/**": true,
        "**/build/**": true
    },

    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true
    }
}